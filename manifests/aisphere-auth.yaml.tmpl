apiVersion: v1
kind: Namespace
metadata:
  name: __NAMESPACE__
---
apiVersion: v1
kind: Secret
metadata:
  name: aisphere-auth-secret
  namespace: __NAMESPACE__
type: Opaque
stringData:
  AISPHERE_CASDOOR_CLIENT_ID: "__CASDOOR_CLIENT_ID__"
  AISPHERE_CASDOOR_CLIENT_SECRET: "__CASDOOR_CLIENT_SECRET__"
  AISPHERE_SERVICE_TOKEN: "__SERVICE_TOKEN__"
  AISPHERE_JWT_SECRET: "__JWT_SECRET__"
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: aisphere-auth
  namespace: __NAMESPACE__
  labels:
    app.kubernetes.io/name: aisphere-auth
    app.kubernetes.io/component: auth-service
spec:
  replicas: __REPLICAS__
  selector:
    matchLabels:
      app.kubernetes.io/name: aisphere-auth
  template:
    metadata:
      labels:
        app.kubernetes.io/name: aisphere-auth
        app.kubernetes.io/component: auth-service
    spec:
      containers:
        - name: aisphere-auth
          image: __IMAGE__
          imagePullPolicy: IfNotPresent
          ports:
            - name: http
              containerPort: 18080
          env:
            - name: AISPHERE_AUTH_ADDR
              value: ":18080"
            - name: AISPHERE_AUTH_MODE
              value: "__AUTH_MODE__"
            - name: AISPHERE_AUTH_PUBLIC_BASE_URL
              value: "__PUBLIC_BASE_URL__"
            - name: AISPHERE_COOKIE_DOMAIN
              value: "__COOKIE_DOMAIN__"
            - name: AISPHERE_COOKIE_SECURE
              value: "__COOKIE_SECURE__"
            - name: AISPHERE_CASDOOR_ENDPOINT
              value: "__CASDOOR_ENDPOINT__"
            - name: AISPHERE_CASDOOR_OWNER
              value: "__CASDOOR_OWNER__"
            - name: AISPHERE_CASDOOR_APPLICATION
              value: "__CASDOOR_APPLICATION__"
            - name: AISPHERE_CASDOOR_REDIRECT_URL
              value: "__CASDOOR_REDIRECT_URL__"
            - name: AISPHERE_CASDOOR_PERMISSION_ID
              value: "__CASDOOR_PERMISSION_ID__"
            - name: AISPHERE_SESSION_PROVIDER
              value: "__SESSION_PROVIDER__"
            - name: AISPHERE_REDIS_ADDRS
              value: "__REDIS_ADDRS__"
            - name: AISPHERE_REDIS_PREFIX
              value: "aisphere"
            - name: AISPHERE_SERVICE_TOKEN_REQUIRED
              value: "true"
            - name: AISPHERE_SERVICE_TOKEN_HEADER
              value: "X-Aisphere-Service-Token"
            - name: AISPHERE_CASDOOR_CLIENT_ID
              valueFrom:
                secretKeyRef:
                  name: aisphere-auth-secret
                  key: AISPHERE_CASDOOR_CLIENT_ID
            - name: AISPHERE_CASDOOR_CLIENT_SECRET
              valueFrom:
                secretKeyRef:
                  name: aisphere-auth-secret
                  key: AISPHERE_CASDOOR_CLIENT_SECRET
            - name: AISPHERE_SERVICE_TOKEN
              valueFrom:
                secretKeyRef:
                  name: aisphere-auth-secret
                  key: AISPHERE_SERVICE_TOKEN
            - name: AISPHERE_JWT_SECRET
              valueFrom:
                secretKeyRef:
                  name: aisphere-auth-secret
                  key: AISPHERE_JWT_SECRET
          readinessProbe:
            httpGet:
              path: /readyz
              port: http
            initialDelaySeconds: 5
            periodSeconds: 10
          livenessProbe:
            httpGet:
              path: /livez
              port: http
            initialDelaySeconds: 10
            periodSeconds: 20
            timeoutSeconds: 2
            failureThreshold: 3
          resources:
            requests:
              cpu: 100m
              memory: 128Mi
            limits:
              cpu: 1000m
              memory: 512Mi
---
apiVersion: v1
kind: Service
metadata:
  name: aisphere-auth
  namespace: __NAMESPACE__
  labels:
    app.kubernetes.io/name: aisphere-auth
spec:
  type: ClusterIP
  selector:
    app.kubernetes.io/name: aisphere-auth
  ports:
    - name: http
      port: 18080
      targetPort: http
